set positional-arguments
set shell := ["bash", "-cu"]

# Fixed port allocation so multiple agents/dev servers don't collide
PORTS := '{"platform":3000,"admin":3001,"mfe-scene":3002,"mfe-intention":3003,"mfe-portal":3004,"chat":3005}'

default:
    @just --list

# ─── dev ────────────────────────────────────────────────
dev app="platform":
    @PORT=$(echo '{{ PORTS }}' | jq -r '.["{{ app }}"]') && \
        echo "→ Starting {{ app }} on :$PORT" && \
        cd apps/{{ app }} && PORT=$PORT pnpm dev

# Start everything (heavy; usually you only need shell + 1 mfe)
dev-all:
    pnpm dev

# ─── build/test ─────────────────────────────────────────
# build [target]: no arg = all apps; or platform | admin | mfe-* | components | ...
build target="":
    @if [ -z "{{ target }}" ]; then \
        echo "→ Building all (turbo)..." && pnpm build; \
    elif echo "{{ target }}" | grep -qE "^mfe-|^(platform|admin)$"; then \
        echo "→ Building app: {{ target }}" && pnpm -F {{ target }} build; \
    elif [ -d "packages/{{ target }}" ]; then \
        echo "→ Building package: {{ target }}" && pnpm -F {{ target }} build; \
    else \
        echo "✗ Unknown target: {{ target }} (not in apps/ or packages/)"; exit 1; \
    fi

test pkg="":
    @if [ -z "{{ pkg }}" ]; then pnpm test; \
    elif echo "{{ pkg }}" | grep -qE "^mfe-|^(platform|admin)$"; then pnpm -F {{ pkg }} test; \
    else pnpm -F {{ pkg }} test; fi

# ─── quality ────────────────────────────────────────────
# Biome 一把梭：lint + format + import sort + 自动修复（safe + unsafe）
lint:
    pnpm exec biome check .
    pnpm typecheck

fmt:
    pnpm exec biome check --write .

# ─── schema ─────────────────────────────────────────────
# Regenerate unified api package from schemas/openapi/*.json
gen-client:
    cd packages/api && bash scripts/codegen.sh
    @echo "✓ api package regenerated"
