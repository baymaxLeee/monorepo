# Telemetry service — copy to .env and adjust.
#
# Telemetry stores RUM events in MySQL (was ClickHouse; switched for the demo
# phase). It shares the same MySQL instance as iam / admin / gateway but
# writes to its own database, mirroring the per-service DB layout.
#
# ENVIRONMENT=development|staging|single-vps|production
# Production refuses to start if MYSQL_HOST is localhost, or if MYSQL_PASSWORD
# is one of the well-known dev defaults (empty, "dev", "password", "admin").
ENVIRONMENT=development

PORT=8008

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_DATABASE=telemetry

SAMPLE_RATE_PERFORM=1.0
SAMPLE_RATE_EVENT=1.0
