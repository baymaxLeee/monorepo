# Telemetry service — copy to .env and adjust.
#
# ENVIRONMENT=development|staging|production
# Production refuses to start if CLICKHOUSE_HOST is localhost, or if
# CLICKHOUSE_USER=default with empty password (no auth = forbidden in prod).
ENVIRONMENT=development

PORT=8008
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=telemetry
SAMPLE_RATE_PERFORM=1.0
SAMPLE_RATE_EVENT=1.0
