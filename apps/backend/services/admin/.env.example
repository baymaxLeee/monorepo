# Admin service — copy to .env and adjust for your machine.
# Requires: `just up` (MySQL + Redis from docker-compose)
#
# ENVIRONMENT=development|staging|production
# In production, the service refuses to start if MYSQL_PASSWORD / MYSQL_HOST /
# REDIS_HOST are still defaults — see src/admin/config.py validator.
ENVIRONMENT=development

# HTTP
PORT=8001

# MySQL (database created by scripts/db-bootstrap.sh)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_DATABASE=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
