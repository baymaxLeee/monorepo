# Admin service — copy to .env and adjust for your machine.
# Requires: `just up` (MySQL + Redis from docker-compose)

# HTTP
PORT=8001

# MySQL (database created by scripts/mysql-init-multi-db.sh)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_DATABASE=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Fernet key used to encrypt model_providers.api_key_enc at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The value below is a *dev fallback*; admin refuses to start in
# ENVIRONMENT=production if this exact string is still configured.
ADMIN_SECRET_KEY=MFnLpzWN-y-Hh0aJtaxKXh4uOFcljnPC6FwpDF4S5Y8=

# Shared secret presented by consumer services (chat, ...) on the
# `/internal/*` API surface. Must match chat/.env INTERNAL_API_TOKEN.
INTERNAL_API_TOKEN=dev-internal-token
