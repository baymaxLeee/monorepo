# Admin service — copy to .env and adjust for your machine.
# Requires: `just up` (Postgres + Redis from docker-compose)

# HTTP
PORT=8001

# Postgres (database created by scripts/pg-init-multi-db.sh)
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/admin

# Redis
REDIS_URL=redis://localhost:6379/0
