# Chat service — copy to .env and adjust for your machine.
# Requires: `just up` (MySQL + Redis from docker-compose)
#
# ENVIRONMENT=development|staging|production
# In production, the service refuses to start if MYSQL_PASSWORD / MYSQL_HOST /
# REDIS_HOST are still defaults — see src/chat/config.py validator.
ENVIRONMENT=development

# HTTP
PORT=8009

# MySQL (database created by scripts/db-bootstrap.sh)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_DATABASE=chat

# Redis (use a different logical DB than gateway/admin)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# LLM upstream (OpenAI-compatible). Empty OPENAI_API_KEY → service falls back
# to a deterministic echo mock so the demo always runs.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
