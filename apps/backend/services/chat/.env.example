# Chat service — copy to .env and adjust for your machine.
# Requires: `just up` (MySQL + Redis from docker-compose)
#
# ENVIRONMENT=development|staging|production
# In production, the service refuses to start if MYSQL_PASSWORD / MYSQL_HOST /
# REDIS_HOST / ADMIN_SERVICE_URL / INTERNAL_API_TOKEN are still defaults —
# see src/chat/config.py validator.
ENVIRONMENT=development

# HTTP
PORT=8009

# MySQL (database created by scripts/db-bootstrap.sh)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_DATABASE=chat

# Redis (use a different logical DB than gateway/admin)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# Admin owns the model_providers domain. chat fetches decrypted credentials
# from `${ADMIN_SERVICE_URL}/internal/providers/...` using INTERNAL_API_TOKEN.
# Configure LLM providers (model / base_url / api_key) in admin MFE
# → 模型管理 — they are encrypted at rest and never exposed to the browser.
ADMIN_SERVICE_URL=http://localhost:8001
INTERNAL_API_TOKEN=dev-internal-token

# Upstream LLM call timeout (seconds).
LLM_TIMEOUT_SECONDS=60
