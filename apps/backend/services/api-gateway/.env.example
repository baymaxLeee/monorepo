# API Gateway — copy to .env and adjust for your machine.
# Requires: `just up` (Postgres + Redis from docker-compose)

PORT=8000
ADMIN_SERVICE_URL=http://localhost:8001

# Postgres (gateway metadata / rate-limit counters demo DB)
DATABASE_URL=postgres://dev:dev@localhost:5432/gateway?sslmode=disable

# Redis (sessions, rate limits, edge cache)
REDIS_URL=redis://localhost:6379/1
