# IAM service — copy to .env and adjust for your machine.
# Requires: `just up` (MySQL from docker-compose)
#
# ENVIRONMENT=development|staging|production
# Production refuses to start if ACCESS_TOKEN_SECRET / MYSQL_PASSWORD /
# MYSQL_HOST are still defaults, or if REFRESH_COOKIE_SECURE != true.
ENVIRONMENT=development

# HTTP
PORT=8002

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=dev
IAM_MYSQL_DATABASE=iam

# Tokens
ACCESS_TOKEN_SECRET=dev-only-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
REFRESH_COOKIE_NAME=refresh_token

# Cross-origin SPA (frontend on Cloudflare, API on backend cluster):
#   REFRESH_COOKIE_SECURE=true
#   REFRESH_COOKIE_SAMESITE=none
#   REFRESH_COOKIE_DOMAIN=.your-domain.com   (share cookie across subdomains)
# Same-origin dev: SECURE=false, SAMESITE=lax, DOMAIN unset.
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax

# Demo seed
SUPER_ADMIN_ID=demo-super-admin
SUPER_ADMIN_ACCOUNT=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_DISPLAY_NAME=Super Admin
