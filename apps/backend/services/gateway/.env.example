# API Gateway — copy to .env and adjust for your machine.
# Requires: `just up` (MySQL + Redis from docker-compose)
#
# ENVIRONMENT=development|staging|production
# Production refuses to start if ACCESS_TOKEN_SECRET / MYSQL_PASSWORD /
# MYSQL_HOST are still defaults, or if ALLOWED_FRONTEND_ORIGINS contains
# localhost/wildcards/non-https entries.
ENVIRONMENT=development

# HTTP
PORT=8000
# Caps incoming request body (defend against resource exhaustion). 1 MiB default.
# MAX_REQUEST_BODY_BYTES=1048576
# HTTP_READ_TIMEOUT=15s
# HTTP_WRITE_TIMEOUT=30s
# HTTP_IDLE_TIMEOUT=120s

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_DATABASE=gateway

# Redis (use a different logical DB than admin)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# Upstream admin service
ADMIN_SERVICE_URL=http://localhost:8001

# Upstream chat service
CHAT_SERVICE_URL=http://localhost:8009

# Upstream iam service
IAM_SERVICE_URL=http://localhost:8002

# Upstream telemetry service
TELEMETRY_SERVICE_URL=http://localhost:8008

ALLOWED_FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT access-token verification (must match iam service ACCESS_TOKEN_SECRET)
ACCESS_TOKEN_SECRET=dev-only-change-me

# Paths exempt from identity propagation (CSV; matched as exact path or "<p>/" prefix).
# Defaults to: /, /healthz, /api/iam-server/account-availability, /api/iam-server/login, /api/iam-server/register, /api/iam-server/refresh, /api/iam-server/logout
# PUBLIC_PATH_PREFIXES=

# Paths where a valid token is propagated when present, but anonymous requests are allowed.
# Defaults to: /api/telemetry-server/rum
# OPTIONAL_AUTH_PATH_PREFIXES=
