# Procfile for `just dev` (read by overmind / mprocs / honcho / foreman).
# Each line = one process. Prefix becomes the label in the multiplexer.
#
# Startup ordering note:
#   - platform depends on mfe-admin's mf-manifest.json at boot.
#   - We don't wait for backend (gateway/svc-admin) — frontend can render before they
#     come online; the API call only fires when the user clicks/loads the list.
#   - We DO wait for mfe-admin's manifest before starting platform.

svc-admin: cd apps/backend/services/admin && uv run uvicorn admin.main:app --reload --port 8001
telemetry: cd apps/backend/services/telemetry && uv run uvicorn telemetry.main:app --reload --port 8008
iam:  cd apps/backend/services/iam && go run ./cmd/server
gateway:   cd apps/backend/services/gateway && go run ./cmd/server
mfe-admin: cd apps/frontend && PORT=3001 pnpm -F admin dev
platform:  ./scripts/wait-for-url.sh http://localhost:3001/mf-manifest.json mfe-admin && cd apps/frontend && PORT=3000 pnpm -F platform dev
