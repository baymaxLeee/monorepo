# Multi-stage build that produces a single nginx image carrying:
#   • the platform host SPA bundle (apps/frontend/apps/platform/dist)
#   • the admin MFE remote bundle  (apps/frontend/apps/admin/dist)
#   • the chat  MFE remote bundle  (apps/frontend/apps/chat/dist)
#   • our nginx.conf
#
# Build context: monorepo root (so we can COPY anywhere under the repo).
# Build command in CI:
#   docker buildx build \
#     -f infra/single-vps/Dockerfile.web \
#     --build-arg API_BASE_URL="" \
#     --build-arg MFE_ADMIN_ENTRY="mfe_admin@/mfe-admin/mf-manifest.json" \
#     --build-arg MFE_CHAT_ENTRY="mfe_chat@/mfe-chat/mf-manifest.json" \
#     -t ghcr.io/<owner>/<repo>/web:<tag> \
#     .

FROM node:22-alpine AS builder

# Enable corepack; the actual pnpm version is taken from frontend/package.json's
# `packageManager` field, which keeps the image in lockstep with local dev.
RUN corepack enable

WORKDIR /app

# Copy the minimum needed for `pnpm install` to hit cache. Order matters for
# layer caching: manifests first, then source.
#
# Note: we intentionally do NOT copy apps/frontend/.npmrc. That file pins
# the registry to an internal (ByteDance) mirror that is not reachable from
# GitHub Actions / public infra; image builds must use the default public
# npm registry. Local devs still use the .npmrc on their machines.
COPY apps/frontend/package.json apps/frontend/pnpm-lock.yaml apps/frontend/pnpm-workspace.yaml apps/frontend/tsconfig.base.json apps/frontend/turbo.json ./apps/frontend/
COPY apps/frontend/mf-shared.mjs apps/frontend/mf-shared.d.mts apps/frontend/workspace-aliases.mjs apps/frontend/rspack.shared.mjs apps/frontend/components.json ./apps/frontend/
COPY apps/frontend/apps ./apps/frontend/apps
COPY apps/frontend/packages ./apps/frontend/packages

WORKDIR /app/apps/frontend

RUN pnpm install --frozen-lockfile

# Build-time configuration. Empty API_BASE_URL → same-origin (nginx proxy).
# MFE remote entries use path-only URLs so they resolve to whatever origin
# the page loaded from (IP / domain agnostic).
ARG API_BASE_URL=""
ARG MFE_ADMIN_ENTRY="mfe_admin@/mfe-admin/mf-manifest.json"
ARG MFE_CHAT_ENTRY="mfe_chat@/mfe-chat/mf-manifest.json"
ARG APP_RELEASE="single-vps"

ENV NODE_ENV=production \
    API_BASE_URL=${API_BASE_URL} \
    MFE_ADMIN_ENTRY=${MFE_ADMIN_ENTRY} \
    MFE_CHAT_ENTRY=${MFE_CHAT_ENTRY} \
    APP_RELEASE=${APP_RELEASE}

# Build remotes first (admin + chat) so their manifests exist when the host
# (platform) consumes the path-based entry URLs at runtime.
RUN pnpm -F admin build && pnpm -F chat build && pnpm -F platform build

FROM nginx:1.27-alpine

# Drop the default config; ours fully replaces it.
RUN rm -f /etc/nginx/conf.d/default.conf
COPY infra/single-vps/nginx.conf /etc/nginx/conf.d/default.conf

# Platform = host (lives at /). Admin / chat = MFE remotes (lives at /mfe-*/).
COPY --from=builder /app/apps/frontend/apps/platform/dist /usr/share/nginx/html
COPY --from=builder /app/apps/frontend/apps/admin/dist    /usr/share/nginx/html/mfe-admin
COPY --from=builder /app/apps/frontend/apps/chat/dist     /usr/share/nginx/html/mfe-chat

# nginx default user is "nginx"; we keep it. EXPOSE for documentation only,
# port mapping is done by docker-compose.
EXPOSE 80

# Health probe runs against /livez which proxies to gateway, but during
# initial boot the gateway may not be up yet — make the probe optional.
HEALTHCHECK --interval=10s --timeout=3s --start-period=15s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://127.0.0.1/index.html || exit 1
