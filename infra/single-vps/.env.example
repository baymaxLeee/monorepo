# Single-VPS deployment configuration.
# Copy to `.env` on the VPS and fill in real values.
#
# Files of this form are intentionally NOT committed; .gitignore covers
# `.env` already.

# ─── Where to pull images from ───────────────────────────────────
# Two options the CI mirrors images to (see .github/workflows/build-images.yml):
#
#   1) GHCR (default, free, public images, no `docker login` on VPS)
#      Format: ghcr.io/<owner>/<repo>            (lowercase; GitHub auto-lowercases)
#      Trade-off: pulls cross the Pacific — ~30 minutes for the first 1GB stack
#      on a 3Mbps China-bound link.
#
#   2) Tencent TCR mirror (recommended for China-hosted VPS)
#      Format: ccr.ccs.tencentyun.com/<namespace>
#      Requires: one-time `docker login ccr.ccs.tencentyun.com` on the VPS
#                 (or set up Tencent Cloud's Lighthouse-internal pull credential)
#      Speed:    intra-Tencent-Cloud, MB/s scale, finishes in seconds.
#
# The CI pushes to both when `vars.TCR_NAMESPACE` is configured in the repo;
# just point IMAGE_REGISTRY at whichever you want this VPS to consume.
IMAGE_REGISTRY=ghcr.io/your-github-user/your-repo-name
# IMAGE_REGISTRY=ccr.ccs.tencentyun.com/your-tcr-namespace

# Which image tag to deploy. Match the tag from build-images.yml:
#   :main           → latest commit on main (mutable, easy)
#   :sha-abc12345   → immutable specific commit (recommended for prod)
#   :v1.2.3         → release tag
IMAGE_TAG=main

# ─── What port to expose on the host ─────────────────────────────
# The browser hits http://<vps-ip>:PUBLIC_PORT
# Pick 8080 to avoid the China-cloud restriction on 80/443 (those need ICP
# 备案). Pick 80 if you already have ICP record + domain.
PUBLIC_PORT=8080

# ─── MySQL ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 24 | tr -d '/+='
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password_min_24_chars
MYSQL_USER=app
MYSQL_PASSWORD=CHANGE_ME_app_password_min_24_chars

# ─── JWT signing ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be the SAME value for gateway and iam; rotating invalidates all
# active sessions.
ACCESS_TOKEN_SECRET=CHANGE_ME_hex_64_chars

# ─── Initial admin account (created by iam on first start) ───────
# You log in with these on the SPA. Change the password after first login.
SUPER_ADMIN_ACCOUNT=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_admin_password
SUPER_ADMIN_DISPLAY_NAME=Super Admin

# ─── Telemetry storage ───────────────────────────────────────────
# Telemetry shares the MySQL instance above; no extra env vars needed.
# (It writes to its own `telemetry` database — created by db-init.)

# ─── Chat / LLM upstream (OpenAI-compatible) ─────────────────────
# All three knobs are optional. When OPENAI_API_KEY is unset the chat
# service falls back to a deterministic mock — fine for demo / smoke tests
# without spending API credits.
#
# To point at a real provider:
#   OpenAI:    OPENAI_BASE_URL=https://api.openai.com/v1
#   DeepSeek:  OPENAI_BASE_URL=https://api.deepseek.com/v1
#   Moonshot:  OPENAI_BASE_URL=https://api.moonshot.cn/v1
#   vLLM:      OPENAI_BASE_URL=http://<your-vllm>:8000/v1
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=30
