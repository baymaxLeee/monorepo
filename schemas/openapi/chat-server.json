          "content",
          "status",
          "created_at"
        ],
        "title": "Message"
      },
      "SendMessageInput": {
        "properties": {
          "content": {
            "type": "string",
            "maxLength": 8000,
            "minLength": 1,
            "title": "Content"
          },
          "thinking": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Thinking",
            "description": "Enable chain-of-thought reasoning when the model supports it."
          },
          "reasoning_effort": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Reasoning Effort",
            "description": "Reasoning compute budget for thinking-enabled models."
          }
        },
        "type": "object",
        "required": [
          "content"
        ],
        "title": "SendMessageInput"
      },
      "UpdateConversationInput": {
