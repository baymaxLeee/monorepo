    "/conversations/{conversation_id}/messages": {
      "post": {
        "tags": [
          "conversations"
        ],
        "summary": "Send Message",
        "description": "Persist user message, stream assistant reply over SSE.\n\nThe response is `text/event-stream`. Each event is `data: <text-chunk>\\n\\n`\nwhere `<text-chunk>` is a JSON-encoded string (so client-side parsing is\ntrivial and binary-safe). A final `data: [DONE]\\n\\n` event signals end.",
        "operationId": "send_message_conversations__conversation_id__messages_post",
        "parameters": [
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Conversation Id"
