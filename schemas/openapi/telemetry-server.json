    "/rum/batch": {
      "post": {
        "tags": [
          "rum"
        ],
        "summary": "Batch",
        "operationId": "batch_rum_batch_post",
        "parameters": [
          {
            "name": "X-Auth-User-ID",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Auth-User-Id"
            }
          },
          {
            "name": "X-Auth-Name",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Auth-Name"
            }
          },
          {
            "name": "X-Auth-Email",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Auth-Email"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RumBatch"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/errors": {
      "get": {
        "tags": [
          "errors"
        ],
        "summary": "List Error Events",
        "operationId": "list_error_events_errors_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "default": 100,
              "title": "Limit"
            }
          },
          {
            "name": "X-Auth-User-ID",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Auth-User-Id"
            }
          },
          {
            "name": "X-Auth-Name",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Auth-Name"
            }
          },
          {
            "name": "X-Auth-Email",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Auth-Email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorEvent": {
        "properties": {
          "ts_server": {
            "type": "string",
            "format": "date-time",
            "title": "Ts Server"
          },
          "app": {
            "type": "string",
            "title": "App"
          },
          "release": {
            "type": "string",
            "title": "Release"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Id"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          },
          "is_admin": {
            "type": "boolean",
            "title": "Is Admin"
          },
          "device_id": {
            "type": "string",
            "title": "Device Id"
          },
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "trace_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Trace Id"
          },
          "route": {
            "type": "string",
            "title": "Route"
          },
          "fingerprint": {
            "type": "string",
            "title": "Fingerprint"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "stack": {
            "type": "string",
            "title": "Stack"
          },
          "payload": {
            "additionalProperties": true,
            "type": "object",
            "title": "Payload"
          }
        },
        "type": "object",
        "required": [
          "ts_server",
          "app",
          "release",
          "user_id",
          "username",
          "is_admin",
          "device_id",
          "session_id",
          "trace_id",
          "route",
          "fingerprint",
          "name",
          "message",
          "stack",
          "payload"
        ],
        "title": "ErrorEvent"
      },
      "ErrorListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ErrorEvent"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "items"
        ],
        "title": "ErrorListResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RumBatch": {
        "properties": {
          "app": {
            "type": "string",
            "enum": [
              "platform",
              "mfe-admin"
            ],
            "title": "App"
          },
          "release": {
            "type": "string",
            "title": "Release",
            "default": ""
          },
          "device_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Device Id"
          },
          "session_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Session Id"
          },
          "user_agent": {
            "type": "string",
            "title": "User Agent",
            "default": ""
          },
          "events": {
            "items": {
              "$ref": "#/components/schemas/RumEvent"
            },
            "type": "array",
            "maxItems": 100,
            "minItems": 1,
            "title": "Events"
          }
        },
        "type": "object",
        "required": [
          "app",
          "device_id",
          "session_id",
          "events"
        ],
        "title": "RumBatch"
      },
      "RumEvent": {
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "perform",
              "error",
              "warning",
              "event"
            ],
            "title": "Type"
          },
          "ts_client": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ts Client"
          },
          "trace_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Trace Id"
          },
          "route": {
            "type": "string",
            "title": "Route",
            "default": ""
          },
          "payload": {
            "additionalProperties": true,
            "type": "object",
            "title": "Payload"
          }
        },
        "type": "object",
        "required": [
          "type"
        ],
        "title": "RumEvent"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
